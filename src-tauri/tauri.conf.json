{
  "productName": "stock_agent",
  "version": "0.1.0",
  "identifier": "com.stockagent.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
